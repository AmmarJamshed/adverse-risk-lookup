# =============================================================================
# Adverse Risk Lookup (ARL) — Environment Configuration
# Copy to .env and fill in values. Never commit .env or hardcode secrets.
# =============================================================================

# Application
APP_NAME=Adverse Risk Lookup
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:5173
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ENCRYPTION_KEY=change-me-fernet-key-32bytes!!

# PostgreSQL (primary DB + pgvector)
# Local Docker Compose default:
DATABASE_URL=postgresql+psycopg2://arl:arl_secure_password@localhost:5432/arl
# Production example:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/arl

# Redis (Celery broker / cache)
REDIS_URL=redis://localhost:6379/0

# NewsAPI — https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Groq AI — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TRANSLATION_MODEL=llama-3.3-70b-versatile

# Embeddings (sentence-transformers locally, or compatible API)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
USE_FAISS_FALLBACK=true

# Appwrite (file storage / optional sync — not a SQL replacement)
# https://fra.cloud.appwrite.io/v1
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key
APPWRITE_BUCKET_ID=arl-uploads

# Scheduler
NEWS_FETCH_INTERVAL_MINUTES=15
CELERY_TIMEZONE=UTC

# Email notifications (optional SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=arl-alerts@example.com
ALERTS_ENABLED=false

# Rate limiting
RATE_LIMIT_PER_MINUTE=120

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
